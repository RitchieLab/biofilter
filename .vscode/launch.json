            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "project",
                "create",
                "--db-uri",
                "postgresql+psycopg2://bioadmin:bioadmin@127.0.0.1:5432/biofilter_test_cli"
