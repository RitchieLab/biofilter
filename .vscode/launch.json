{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Bio - Start Project",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/runs_debugs/Start_Project.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        },
        {
            "name": "Bio - ETL Manager",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/runs_debugs/Run_ETLManager.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        },
        {
            "name": "Bio - Reports Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/runs_debugs/Run_Reports.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        },
        {
            "name": "Bio - Run Any Script (pick)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/${input:scriptPath}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        },
        {
            "name": "CLI - DB Create (SQLite)",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "db",
                "create-db",
                "--db-uri",
                "${input:sqliteDbUri}",
                "--overwrite"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - DB Upgrade",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "db",
                "upgrade"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - DB Migrate Status",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "db",
                "migrate",
                "--status"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - DB Export (CSV)",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "db",
                "export",
                "--out",
                "${input:bundleDir}",
                "--format",
                "csv"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - DB Import (CSV)",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "db",
                "import",
                "--in",
                "${input:bundleDir}",
                "--format",
                "csv"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - Report List",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "report",
                "list"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - Report Explain",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "report",
                "explain",
                "--report-name",
                "${input:reportName}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - Report Run (CSV)",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "report",
                "run",
                "--name",
                "${input:reportName}",
                "--as-csv",
                "--output",
                "${input:reportOutputCsv}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - ETL Update (dbsnp_sample)",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "etl",
                "update",
                "--data-source",
                "dbsnp_sample"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "CLI - ETL Index (genes + variant)",
            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "${input:dbUri}",
                "etl",
                "index",
                "--group",
                "genes",
                "--group",
                "variant"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "Pytest - Integration CLI (SQLite)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-m",
                "integration and not postgres",
                "tests/integration/cli",
                "-q"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "Pytest - Integration Report",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/integration/cli/test_cli_report.py",
                "-q"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "Pytest - Integration DB Lifecycle",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/integration/cli/test_cli_db_lifecycle.py",
                "-q"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        }
    ],
    "compounds": [
        {
            "name": "Smoke - Integration SQLite",
            "configurations": [
                "Pytest - Integration CLI (SQLite)",
                "Pytest - Integration Report"
            ]
        }
    ],
    "inputs": [
        {
            "id": "scriptPath",
            "type": "promptString",
            "description": "Path (relative to workspace) of script to run",
            "default": "scripts/runs_debugs/Run_Reports.py"
        },
        {
            "id": "dbUri",
            "type": "promptString",
            "description": "Database URI for CLI commands",
            "default": "sqlite:///${workspaceFolder}/biofilter_dev_cli.db"
        },
        {
            "id": "sqliteDbUri",
            "type": "promptString",
            "description": "SQLite DB URI used by create-db",
            "default": "sqlite:///${workspaceFolder}/biofilter_dev_cli.db"
        },
        {
            "id": "bundleDir",
            "type": "promptString",
            "description": "Export/import bundle directory",
            "default": "${workspaceFolder}/tests/outputs/export_sqlite/cli"
        },
        {
            "id": "reportName",
            "type": "promptString",
            "description": "Report identifier",
            "default": "etl_status"
        },
        {
            "id": "reportOutputCsv",
            "type": "promptString",
            "description": "CSV output path for report run",
            "default": "${workspaceFolder}/tests/outputs/reports/report_output.csv"
        }
    ]
}
