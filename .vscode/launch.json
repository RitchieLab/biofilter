            "type": "debugpy",
            "request": "launch",
            "module": "biofilter.api.cli.main",
            "args": [
                "--db-uri",
                "postgresql+psycopg2://bioadmin:bioadmin@localhost/biofilter_prod",
                "db",
                "export",
                "--out",
