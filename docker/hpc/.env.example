# HPC image — BF4 + PostgreSQL in one container.
# PostgreSQL only listens on localhost inside the container (trust auth).

# Database identity (created on first run if PGDATA is empty).
POSTGRES_USER=biofilter
POSTGRES_DB=biofilter
POSTGRES_PORT=5432

# Path inside the container; the host directory bind-mounted here is where
# the database actually persists. Do not change unless you also change the
# bind-mount target.
PGDATA=/var/lib/postgresql/data

# Set to 1 to run `biofilter db migrate --target head` automatically on startup.
BIOFILTER_AUTO_MIGRATE=0

# Optional: path inside the container to a `pg_dump -Fc` archive. When set
# and PGDATA is empty, the dump is restored on first run. Mount the dump
# read-only with `-v /host/path/biofilter.dump:/restore.dump:ro`.
# BIOFILTER_RESTORE_DUMP=/restore.dump
# BIOFILTER_RESTORE_JOBS=4
